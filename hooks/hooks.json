{
  "description": "Session lifecycle hooks for hyperclaude",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start-reminder.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "^(hyperclaude:)?hyper-loop(-cancel)?$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/hyper-loop-intake.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/hyper-loop-stop.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
